{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "containerGroupName": {
      "type": "string",
      "defaultValue": "f1-fantasy-live-score-aci",
      "metadata": {
        "description": "Name for the container group resource."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the container group."
      }
    },
    "containerImage": {
      "type": "string",
      "defaultValue": "f1fantasyacr.azurecr.io/f1-fantasy-live-score:latest",
      "metadata": {
        "description": "Full container image name including registry and tag."
      }
    },
    "cpu": {
      "type": "string",
      "defaultValue": "1",
      "metadata": {
        "description": "Number of CPU cores for the container (passed as string, converted via json())."
      }
    },
    "memoryInGb": {
      "type": "string",
      "defaultValue": "2",
      "metadata": {
        "description": "Memory in GB for the container. Set to 2 GB for Puppeteer/Chrome headless."
      }
    },
    "restartPolicy": {
      "type": "string",
      "defaultValue": "OnFailure",
      "allowedValues": [
        "Always",
        "OnFailure",
        "Never"
      ],
      "metadata": {
        "description": "Container restart policy."
      }
    },
    "acrServer": {
      "type": "string",
      "defaultValue": "f1fantasyacr.azurecr.io",
      "metadata": {
        "description": "Azure Container Registry server hostname."
      }
    },
    "acrUsername": {
      "type": "string",
      "defaultValue": "f1fantasyacr",
      "metadata": {
        "description": "Username for Azure Container Registry authentication."
      }
    },
    "acrPassword": {
      "type": "secureString",
      "metadata": {
        "description": "Password for Azure Container Registry authentication."
      }
    },
    "azureStorageConnectionString": {
      "type": "secureString",
      "metadata": {
        "description": "Connection string for Azure Storage (blob/table)."
      }
    },
    "azureStorageContainerName": {
      "type": "string",
      "defaultValue": "f1-fantasy-scraper-json",
      "metadata": {
        "description": "Azure Storage blob container name for scraped data."
      }
    },
    "telegramBotToken": {
      "type": "secureString",
      "metadata": {
        "description": "Telegram bot token for sending notifications."
      }
    },
    "telegramLogChannelId": {
      "type": "string",
      "metadata": {
        "description": "Telegram channel ID for log messages."
      }
    },
    "telegramErrorsChannelId": {
      "type": "string",
      "metadata": {
        "description": "Telegram channel ID for error notifications."
      }
    },
    "pollingIntervalMs": {
      "type": "string",
      "defaultValue": "30000",
      "metadata": {
        "description": "Polling interval in milliseconds between scrape cycles."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[parameters('containerGroupName')]",
      "location": "[parameters('location')]",
      "properties": {
        "containers": [
          {
            "name": "[parameters('containerGroupName')]",
            "properties": {
              "image": "[parameters('containerImage')]",
              "resources": {
                "requests": {
                  "cpu": "[json(parameters('cpu'))]",
                  "memoryInGB": "[json(parameters('memoryInGb'))]"
                }
              },
              "environmentVariables": [
                {
                  "name": "AZURE_STORAGE_CONNECTION_STRING",
                  "secureValue": "[parameters('azureStorageConnectionString')]"
                },
                {
                  "name": "AZURE_STORAGE_CONTAINER_NAME",
                  "value": "[parameters('azureStorageContainerName')]"
                },
                {
                  "name": "TELEGRAM_BOT_TOKEN",
                  "secureValue": "[parameters('telegramBotToken')]"
                },
                {
                  "name": "TELEGRAM_LOG_CHANNEL_ID",
                  "value": "[parameters('telegramLogChannelId')]"
                },
                {
                  "name": "TELEGRAM_ERRORS_CHANNEL_ID",
                  "value": "[parameters('telegramErrorsChannelId')]"
                },
                {
                  "name": "POLLING_INTERVAL_MS",
                  "value": "[parameters('pollingIntervalMs')]"
                }
              ]
            }
          }
        ],
        "osType": "Linux",
        "restartPolicy": "[parameters('restartPolicy')]",
        "imageRegistryCredentials": [
          {
            "server": "[parameters('acrServer')]",
            "username": "[parameters('acrUsername')]",
            "password": "[parameters('acrPassword')]"
          }
        ]
      }
    }
  ],
  "outputs": {
    "containerGroupResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName'))]"
    }
  }
}
